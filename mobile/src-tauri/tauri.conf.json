{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Portal",
  "version": "0.1.0",
  "identifier": "org.cosmicfrontier.agentportal",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Portal",
        "url": "https://localhost:3000",
        "width": 430,
        "height": 932,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
