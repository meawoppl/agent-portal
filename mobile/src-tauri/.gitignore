# Rust build artifacts (this crate is excluded from the root workspace, so it
# has its own target/ dir).
/target

# Generated Tauri schemas / platform glue (regenerated by the Tauri CLI).
/gen

# Generated native projects — NOT committed in the E1 scaffold. They require
# SDK/NDK (Android) and Xcode (iOS) and are created in F1/F2 via
# `tauri android init` / `tauri ios init`.
/gen/android
/gen/apple
